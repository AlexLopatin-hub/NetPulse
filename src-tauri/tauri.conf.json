{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "netpulse",
  "version": "0.1.0",
  "identifier": "io.github.alexlopatinhub.netpulse",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Netpulse",
        "width": 400,
        "height": 200,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "skipTaskbar": true,
        "visible": true
      },
      {
        "label": "settings",
        "url": "/settings",
        "title": "Настройки — NetPulse",
        "width": 460,
        "height": 420,
        "resizable": false,
        "decorations": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
